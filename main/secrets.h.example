/*
 * Local secrets — copy this file to secrets.h and fill in your values.
 * secrets.h is in .gitignore and will NOT be committed.
 *
 * These defaults are written to NVS on first boot so that OTA mode
 * can connect to your WiFi automatically (no web form entry needed).
 */
#pragma once

/* WiFi credentials for OTA mode */
#define DEFAULT_WIFI_SSID   "YourSSID"
#define DEFAULT_WIFI_PASS   "YourPassword"

/* Optional: firmware URL for auto-fetch OTA.
 * Leave empty ("") to skip auto-fetch and use manual upload via browser. */
#define DEFAULT_OTA_URL     ""
